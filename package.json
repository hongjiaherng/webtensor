{
  "name": "webtensor-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.12",
    "@vitest/browser": "^4.1.4",
    "@vitest/browser-playwright": "^4.1.4",
    "@webgpu/types": "^0.1.40",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-unused-imports": "^4.4.1",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.4"
  },
  "scripts": {
    "build": "bun run build:ir && bun run build:runtime && bun run build:core && bun run build:backends",
    "build:ir": "bun run --cwd packages/ir build",
    "build:runtime": "bun run --cwd packages/runtime build",
    "build:core": "bun run --cwd packages/core build",
    "build:backends": "bun run --cwd packages/backend-cpu build && bun run --cwd packages/backend-webgpu build && bun run --cwd packages/backend-wasm build",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "diagrams": "plantuml -tsvg docs/diagrams/*.puml"
  }
}
