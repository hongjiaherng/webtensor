{
  "name": "webtensor-workspace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.12",
    "@vitest/browser": "^4.1.4",
    "@vitest/browser-playwright": "^4.1.4",
    "@webgpu/types": "^0.1.40",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-unused-imports": "^4.4.1",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.4"
  },
  "scripts": {
    "setup": "bun install && cd docs && bun install",
    "build": "bun run build:ir && bun run build:runtime && bun run build:core && bun run build:backend-cpu && bun run build:backend-webgpu && bun run build:backend-wasm && bun run build:nn",
    "build:ir": "bun run --cwd packages/ir build",
    "build:runtime": "bun run --cwd packages/runtime build",
    "build:core": "bun run --cwd packages/core build",
    "build:backend-cpu": "bun run --cwd packages/backend-cpu build",
    "build:backend-webgpu": "bun run --cwd packages/backend-webgpu build",
    "build:backend-wasm": "bun run --cwd packages/backend-wasm build",
    "build:nn": "bun run --cwd packages/nn build",
    "clean": "bun scripts/clean.ts",
    "clean:all": "bun scripts/clean.ts --all",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "docs:dev": "cd docs && bun run dev",
    "docs:build": "cd docs && bun run build",
    "docs:start": "cd docs && bun run start",
    "docs:plantuml": "plantuml -tsvg -failfast2 docs/diagrams/puml/*.puml -o ../../public/diagrams",
    "docs:logo": "cd assets/logo && uv sync && uv run main.py",
    "smoke-test": "cd smoke-test && bun run dev",
    "publish:all": "bun publish --cwd packages/ir --access public && bun publish --cwd packages/runtime --access public && bun publish --cwd packages/core --access public && bun publish --cwd packages/backend-cpu --access public && bun publish --cwd packages/backend-webgpu --access public && bun publish --cwd packages/backend-wasm --access public && bun publish --cwd packages/nn --access public"
  }
}
