{
  "name": "@webtensor/nn",
  "version": "0.3.5",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target browser --external @webtensor/core --external @webtensor/ir --external @webtensor/runtime && tsc --emitDeclarationOnly"
  },
  "dependencies": {
    "@webtensor/core": "workspace:^",
    "@webtensor/ir": "workspace:^",
    "@webtensor/runtime": "workspace:^"
  }
}
