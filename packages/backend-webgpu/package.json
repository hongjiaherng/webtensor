{
  "name": "@webtensor/backend-webgpu",
  "version": "0.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target browser --loader .wgsl:text --external @webtensor/ir --external @webtensor/runtime && tsc --emitDeclarationOnly"
  },
  "dependencies": {
    "@webtensor/ir": "workspace:*",
    "@webtensor/runtime": "workspace:*"
  },
  "devDependencies": {
    "@webgpu/types": "^0.1.40"
  }
}
