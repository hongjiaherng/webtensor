{
  "name": "@webtensor/backend-wasm",
  "version": "0.3.0",
  "description": "WASM backend for webtensor using wasm-bindgen",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:wasm": "wasm-pack build rust --target bundler --out-dir ../pkg",
    "build:bundle": "bun build.ts",
    "build:types": "tsc --emitDeclarationOnly",
    "build": "bun run build:wasm && bun run build:bundle && bun run build:types"
  },
  "dependencies": {
    "@webtensor/ir": "workspace:*",
    "@webtensor/runtime": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@types/node": "^25.6.0"
  }
}
