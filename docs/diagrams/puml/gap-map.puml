@startuml gap-map
title Webtensor — What Works vs What's Missing

skinparam backgroundColor #FAFAFA
skinparam shadowing false
skinparam DefaultFontName "Segoe UI"
skinparam rectangle {
  BackgroundColor<<done>> #C8E6C9
  BackgroundColor<<partial>> #FFE0B2
  BackgroundColor<<missing>> #FFCDD2
  BackgroundColor<<bug>> #EF9A9A
  BorderColor #555
}

package "Ops (forward)" {
  rectangle "Add Sub Mul Div\n(broadcast OK)" <<done>>
  rectangle "Unary math\n(neg/exp/log/sqrt\nabs/pow/sigmoid/tanh)" <<done>>
  rectangle "Relu + ReluBackward" <<done>>
  rectangle "Views\n(transpose/reshape/slice\npermute/expand/squeeze/unsqueeze)" <<done>>
  rectangle "MatMul\n(1D / 2D / N-D batched)" <<done>>
  rectangle "Reduce\n(sum / mean / all / any)" <<done>>
  rectangle "Softmax" <<done>>
  rectangle "Concat + Pad" <<done>>
  rectangle "Compare (eq/ne/lt/le/gt/ge/isclose)\n+ Cast" <<done>>
  rectangle "Gather / Scatter\n(advanced indexing)" <<missing>>
  rectangle "LogSoftmax" <<missing>>
}

package "Autograd" {
  rectangle "All shipped ops have backward" <<done>>
  rectangle "Broadcast-aware sumToShape" <<done>>
  rectangle "Expand / Slice / Concat / Pad backward" <<done>>
  rectangle "Higher-order gradients" <<partial>>
  rectangle "Abs backward (needs sign op)" <<missing>>
}

package "Backends" {
  rectangle "CPU (TS)" <<done>>
  rectangle "WASM (Rust)" <<done>>
  rectangle "WebGPU (WGSL)" <<done>>
  rectangle "32/32 kernel parity\nacross 3 backends" <<done>>
  rectangle "Rank ≤ 64 on all backends\n(520-byte TensorMeta)" <<done>>
  rectangle "Max-rank guard at allocate()" <<done>>
}

package "DTypes" {
  rectangle "float32 kernels" <<done>>
  rectangle "Type system + alloc/IO\nfor int32 / bool" <<done>>
  rectangle "Compare ops accept any dtype\n+ Cast between dtypes" <<done>>
  rectangle "int32 / bool arithmetic\nand reduction kernels" <<missing>>
  rectangle "float16 / bfloat16" <<missing>>
}

package "Training infra" {
  rectangle "Eager autograd" <<done>>
  rectangle "compile(fn, spec) + grad(loss, p)" <<done>>
  rectangle "SGD (momentum optional)" <<done>>
  rectangle "mseLoss" <<done>>
  rectangle "End-to-end XOR MLP trains\non all 3 backends" <<done>>
  rectangle "crossEntropy / bceLoss / logSoftmax" <<missing>>
  rectangle "Adam / lr schedulers" <<missing>>
  rectangle "Dataloader / batching" <<missing>>
  rectangle "train() / eval() mode + dropout" <<missing>>
}

package "Distribution" {
  rectangle "dist/ artifacts present" <<done>>
  rectangle "publish:all script" <<partial>>
  rectangle "Version drift\n(backend-wasm 0.1.0, others 0.0.0)" <<bug>>
  rectangle "ESLint error on scripts/clean.mjs" <<bug>>
  rectangle "ONNX import" <<missing>>
  rectangle "Devtools / visualization" <<missing>>
}

@enduml
